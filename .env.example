# ========================================
# 应用配置
# ========================================
APP_NAME=Multi-Tool AI Agent
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-this

# ========================================
# 数据库配置
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ========================================
# LLM 配置
# ========================================
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_MODEL=claude-sonnet-4-20250514
TEMPERATURE=0.7
MAX_TOKENS=8192

# ========================================
# Token 预算配置
# ========================================
MAX_CONTEXT_TOKENS=200000
WORKING_BUDGET=32000
SHORT_MEMORY_SLOT=4000
LONG_MEMORY_SLOT=6000
TOOL_OUTPUT_SLOT=8000

# ========================================
# Memory 配置
# ========================================
SHORT_MEMORY_TTL=86400
LONG_MEMORY_NAMESPACE=user_profiles

# ========================================
# Skills 配置
# ========================================
PROJECT_SKILLS_DIR=skills
GLOBAL_SKILLS_DIR=~/.agents/skills
SKILL_HOT_RELOAD=true

# ========================================
# Tools 配置
# ========================================
TAVILY_API_KEY=your_tavily_api_key_here
READ_FILE_ALLOWED_DIRS=["/Users/josh/Documents/work/learn_test/AI Developer Assistant/agent_app"]
TOOL_TIMEOUT=30

# ========================================
# CORS 配置
# ========================================
CORS_ORIGINS=http://localhost:3000

# ========================================
# 安全配置
# ========================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080
ENABLE_RLS=true

# ========================================
# 可观测性配置
# ========================================
ENABLE_SSE=true

# ========================================
# 前端环境变量 (NEXT_PUBLIC_*)
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# ========================================
# Docker 配置
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_db
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000
OLLAMA_PORT=11434

# ========================================
# 可选服务
# ========================================
# REDIS_URL=redis://localhost:6379/0
# GRAFANA_CLOUD_PROMETHEUS_USERNAME=
# GRAFANA_CLOUD_PROMETHEUS_PASSWORD=
# GRAFANA_CLOUD_LOKI_USERNAME=
# GRAFANA_CLOUD_LOKI_PASSWORD=
