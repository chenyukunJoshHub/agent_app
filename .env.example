# ========================================
# 应用配置
# ========================================
APP_NAME=Multi-Tool AI Agent
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-this

# ========================================
# 数据库配置
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ========================================
# LLM 配置
# ========================================
# Options: ollama, deepseek, zhipu, openai, anthropic
LLM_PROVIDER=ollama

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm4:latest
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT=300

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_TIMEOUT=120

# Zhipu AI Configuration
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash
ZHIPU_TEMPERATURE=0.7

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=120

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_TIMEOUT=120
ANTHROPIC_MAX_TOKENS=8192

# Legacy configuration (for backward compatibility)
DEFAULT_MODEL=claude-sonnet-4-20250514
TEMPERATURE=0.7
MAX_TOKENS=8192

# ========================================
# Token 预算配置
# ========================================
TOKEN_MODEL_CONTEXT_WINDOW=200000
TOKEN_WORKING_BUDGET=32768
TOKEN_MAX_OUTPUT=8192
TOKEN_SLOT_OUTPUT=8192
TOKEN_SLOT_SYSTEM=2000
TOKEN_SLOT_ACTIVE_SKILL=0
TOKEN_SLOT_FEW_SHOT=0
TOKEN_SLOT_RAG=0
TOKEN_SLOT_EPISODIC=500
TOKEN_SLOT_PROCEDURAL=0
TOKEN_SLOT_TOOLS=1200
TOKEN_AUTOCOMPACT_BUFFER_RATIO=0.165

# ========================================
# Memory 配置
# ========================================
SHORT_MEMORY_TTL=86400
LONG_MEMORY_NAMESPACE=user_profiles
MEMORY_PROFILE_UPDATE_MODE=rule
MEMORY_PROFILE_LLM_INTERVAL=10
MEMORY_PROFILE_OPINION_MIN_CONFIDENCE=0.9
TASK_PLANNER_MODE=rule
TASK_PLANNER_MAX_STEPS=8

# ========================================
# Skills 配置
# ========================================
PROJECT_SKILLS_DIR=skills
GLOBAL_SKILLS_DIR=~/.agents/skills
SKILL_HOT_RELOAD=true

# ========================================
# Tools 配置
# ========================================
TAVILY_API_KEY=your_tavily_api_key_here
READ_FILE_ALLOWED_DIRS=["/Users/josh/Documents/work/learn_test/AI Developer Assistant/agent_app"]
# Project root for resolving relative paths in read_file (leave empty to auto-detect)
# WORKSPACE_DIR=/Users/josh/Documents/work/learn_test/AI Developer Assistant/agent_app
TOOL_TIMEOUT=30

# ========================================
# CORS 配置
# ========================================
CORS_ORIGINS=http://localhost:3000

# ========================================
# 安全配置
# ========================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080
ENABLE_RLS=true

# ========================================
# 可观测性配置
# ========================================
ENABLE_SSE=true

# ========================================
# 前端环境变量 (NEXT_PUBLIC_*)
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# ========================================
# Docker 配置
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_db
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000
OLLAMA_PORT=11434

# ========================================
# 可选服务
# ========================================
# REDIS_URL=redis://localhost:6379/0
# GRAFANA_CLOUD_PROMETHEUS_USERNAME=
# GRAFANA_CLOUD_PROMETHEUS_PASSWORD=
# GRAFANA_CLOUD_LOKI_USERNAME=
# GRAFANA_CLOUD_LOKI_PASSWORD=
