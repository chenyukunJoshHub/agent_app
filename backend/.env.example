# ────────────────────────────────────────────────────────────────────────────────
# Environment Configuration for Multi-Tool AI Agent
# ────────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_db

# LLM Provider (choose one)
LLM_PROVIDER=ollama  # Options: ollama, deepseek, zhipu, openai

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5
OLLAMA_TIMEOUT=300

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=120

# Zhipu AI (智谱)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash

# OpenAI Compatible (DeepSeek also uses this)
OPENAI_API_KEY=your_openai_or_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_TIMEOUT=120

# Tools API
TAVILY_API_KEY=your_tavily_api_key_here

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# Server timeouts
HTTP_TIMEOUT=300
KEEP_ALIVE_TIMEOUT=5

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010
